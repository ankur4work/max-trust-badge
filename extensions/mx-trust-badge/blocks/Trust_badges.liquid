{% assign plan = shop.metafields.custom["trust-badges"] %}

{%- comment -%}
plan values expected:
- blank or "free"  → Free tier
- "Basic"          → Paid tier (PREMIUM_PLAN in app)
- (optional) "premium" → also treat as paid if used in older versions
{%- endcomment -%}

{%- assign is_premium = false -%}
{%- if plan == 'Basic' or plan == 'premium' -%}
  {%- assign is_premium = true -%}
{%- endif -%}

<style>
.mxt_badge-img {
  width: {% if is_premium %}{{ block.settings.icon_size_mobile | default: 40 }}{% else %}40{% endif %}px;
  height: {% if is_premium %}{{ block.settings.icon_size_mobile | default: 40 }}{% else %}40{% endif %}px;
  object-fit: contain;
}

.mxt_container {
  width: 100%;
  display: flex;
  justify-content: center;
}

.mxt_features-list {
  display: flex;
  width: 100%;
}

/* Base item style */
.mxt_feature-item {
  display: flex;
  flex-direction: column; /* default: column (used by horizontal layout) */
  align-items: center;
  text-align: center;
  padding: 6px;
  width: 100%;
  gap: 5px;
}

.mxt_feature-icon img {
  width: {% if is_premium %}{{ block.settings.icon_size_mobile | default: 40 }}{% else %}40{% endif %}px;
  height: {% if is_premium %}{{ block.settings.icon_size_mobile | default: 40 }}{% else %}40{% endif %}px;
  object-fit: contain;
  margin-bottom: 4px;
}

.mxt_feature-title {
  font-weight: 600;
  font-size: {% if is_premium %}{{ block.settings.title_font_size_mobile | default: 12 }}{% else %}12{% endif %}px;
}

.mxt_feature-desc {
  font-size: {% if is_premium %}{{ block.settings.desc_font_size_mobile | default: 13 }}{% else %}13{% endif %}px;
  font-weight: 400;
}

/* ---------- HORIZONTAL LAYOUT: 3 in a row ---------- */
.mxt_container.horizontal .mxt_features-list {
  flex-direction: row;
  justify-content: space-between;
  gap: 8px;
}

.mxt_container.horizontal .mxt_feature-item {
  flex: 0 0 calc(33.333% - 8px); /* 3 items per row */
  max-width: calc(33.333% - 8px);
}

/* ---------- VERTICAL LAYOUT: 1 per row ---------- */
.mxt_container.vertical .mxt_features-list {
  flex-direction: column;
  align-items: stretch;
  gap: 10px;
}

.mxt_container.vertical .mxt_feature-item {
  flex-direction: row; /* icon left, text right */
  align-items: center;
  text-align: left;
  max-width: 100%;
  gap: 9px;
  padding: 15px;
}

/* ---------- DESKTOP OVERRIDES ---------- */
@media (min-width: 768px) {
  .mxt_feature-icon img {
    width: {% if is_premium %}{{ block.settings.icon_size_desktop | default: 40 }}{% else %}40{% endif %}px;
    height: {% if is_premium %}{{ block.settings.icon_size_desktop | default: 40 }}{% else %}40{% endif %}px;
  }

  .mxt_badge-img {
    width: {% if is_premium %}{{ block.settings.icon_size_desktop | default: 40 }}{% else %}40{% endif %}px;
    height: {% if is_premium %}{{ block.settings.icon_size_desktop | default: 40 }}{% else %}40{% endif %}px;
  }

  .mxt_feature-title {
    font-size: {% if is_premium %}{{ block.settings.title_font_size_desktop | default: 14 }}{% else %}14{% endif %}px;
  }

  .mxt_feature-desc {
    font-size: {% if is_premium %}{{ block.settings.desc_font_size_desktop | default: 14 }}{% else %}14{% endif %}px;
  }
}
</style>

{%- comment -%}
Free tier:
- Fallback icons only
- Fixed size (40px), fixed colors & radius
- Layout forced to horizontal
- Merchant can still edit badge titles & descriptions

Paid tier ("Basic" / "premium"):
- Custom icons from settings
- Custom layout (horizontal / vertical)
- Custom colors, radius, font sizes, icon sizes
{%- endcomment -%}

<div class="mxt_container {% if is_premium %}{{ block.settings.layout_type }}{% else %}horizontal{% endif %}">
  <div class="mxt_features-list">

    {% assign fallback_images = "trust-trck.png-1.png,easyreturn3.png,check-out.png" | split: "," %}
    {% assign fallback_titles = "Fast Delivery,Secure Purchase,Trusted Quality" | split: "," %}
    {% assign fallback_descriptions = "Quick & reliable shipping,Safe checkout,Top rated by customers" | split: "," %}

    {% for i in (1..3) %}
      {% assign icon_image = 'icon_image_' | append: i %}
      {% assign title = 'title_' | append: i %}
      {% assign desc = 'desc_' | append: i %}

      <div
        class="mxt_feature-item"
        style="
          background-color: {% if is_premium %}{{ block.settings.main_bg_color }}{% else %}#ffffff{% endif %};
          border-radius: {% if is_premium %}{{ block.settings.border_radius | default: 10 }}{% else %}10{% endif %}px;
        "
      >
        <div class="mxt_feature-icon">
          {% if is_premium and block.settings[icon_image] != blank %}
            <img
              src="{{ block.settings[icon_image] | image_url: width: 80 }}"
              class="mxt_badge-img"
              height=""
              width=""
            >
          {% else %}
            <img
              src="{{ fallback_images[forloop.index0] | asset_url }}"
              class="mxt_badge-img"
              height=""
              width=""
            >
          {% endif %}
        </div>

        <div class="mxt_details">
          <div
            class="mxt_feature-title"
            style="color: {% if is_premium %}{{ block.settings.title_color }}{% else %}#000000{% endif %}"
          >
            {% if block.settings[title] != blank %}
              {{ block.settings[title] }}
            {% else %}
              {{ fallback_titles[forloop.index0] }}
            {% endif %}
          </div>

          <div
            class="mxt_feature-desc"
            style="color: {% if is_premium %}{{ block.settings.desc_color }}{% else %}#555555{% endif %}"
          >
            {% if block.settings[desc] != blank %}
              {{ block.settings[desc] }}
            {% else %}
              {{ fallback_descriptions[forloop.index0] }}
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>
</div>

{% schema %}
{
  "name": "Trust Badge",
  "target": "section",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [

    {
      "type": "select",
      "id": "layout_type",
      "label": "Layout",
      "options": [
        { "value": "horizontal", "label": "Horizontal" },
        { "value": "vertical", "label": "Vertical" }
      ],
      "default": "horizontal"
    },

    { "type": "color", "id": "main_bg_color", "label": "Background Color", "default": "#FFFFFF" },
    { "type": "color", "id": "title_color", "label": "Title Color", "default": "#000000" },
    { "type": "color", "id": "desc_color", "label": "Description Color", "default": "#555555" },

    {
      "type": "range",
      "id": "border_radius",
      "label": "Border Radius",
      "min": 5,
      "max": 50,
      "default": 10
    },

    {
      "type": "header",
      "content": "Icon size"
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Icon size (mobile, px)",
      "min": 16,
      "max": 80,
      "default": 40
    },
    {
      "type": "range",
      "id": "icon_size_desktop",
      "label": "Icon size (desktop, px)",
      "min": 16,
      "max": 80,
      "default": 40
    },

    {
      "type": "header",
      "content": "Title font size"
    },
    {
      "type": "range",
      "id": "title_font_size_mobile",
      "label": "Title font size (mobile, px)",
      "min": 10,
      "max": 30,
      "default": 12
    },
    {
      "type": "range",
      "id": "title_font_size_desktop",
      "label": "Title font size (desktop, px)",
      "min": 10,
      "max": 30,
      "default": 14
    },

    {
      "type": "header",
      "content": "Description font size"
    },
    {
      "type": "range",
      "id": "desc_font_size_mobile",
      "label": "Description font size (mobile, px)",
      "min": 10,
      "max": 30,
      "default": 13
    },
    {
      "type": "range",
      "id": "desc_font_size_desktop",
      "label": "Description font size (desktop, px)",
      "min": 10,
      "max": 30,
      "default": 14
    },

    { "type": "header", "content": "Badge 1" },
    { "type": "image_picker", "id": "icon_image_1", "label": "Upload Icon" },
    { "type": "text", "id": "title_1", "label": "Title" },
    { "type": "textarea", "id": "desc_1", "label": "Description" },

    { "type": "header", "content": "Badge 2" },
    { "type": "image_picker", "id": "icon_image_2", "label": "Upload Icon" },
    { "type": "text", "id": "title_2", "label": "Title" },
    { "type": "textarea", "id": "desc_2", "label": "Description" },

    { "type": "header", "content": "Badge 3" },
    { "type": "image_picker", "id": "icon_image_3", "label": "Upload Icon" },
    { "type": "text", "id": "title_3", "label": "Title" },
    { "type": "textarea", "id": "desc_3", "label": "Description" }
  ]
}
{% endschema %}